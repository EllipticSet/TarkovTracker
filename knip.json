{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "supabase/functions/**",
    "app/server/api/changelog.get.ts",
    "app/server/api/contributors.get.ts",
    "scripts/precompute/nuxt-imports.ts"
  ],
  "ignoreDependencies": [
    "@codecov/nuxt-plugin",
    "@iconify-json/mdi",
    "@semantic-release/npm",
    "@tailwindcss/postcss",
    "autoprefixer",
    "defu",
    "lru-cache",
    "postcss",
    "vitest-environment-nuxt",
    "vue-tsc"
  ],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [
        "app/i18n.config.ts",
        "scripts/measure-pageload.mjs",
        "scripts/stripe-import-test.mjs"
      ]
    },
    "workers/api-gateway": {
      "entry": ["src/**/__tests__/**/*.test.ts"],
      "project": ["scripts/**/*.ts", "src/**/*.ts"]
    }
  }
}
