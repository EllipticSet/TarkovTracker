  "name": "tarkovtracker-nuxt",
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "design:lint": "design.md lint DESIGN.md",
    "deps": "taze --r --I",
    "dev": "nuxt dev",
    "format": "prettier --write \"app/**/*.{js,ts,tsx,vue,json,css,md}\" \"docs/**/*.{md,markdown}\" \"*.md\" \".github/**/*.md\" \"DESIGN.md\" \"nuxt.config.ts\" \"app/app.config.ts\" \"vitest.config.ts\" \"tests/test-setup.ts\" && NODE_ENV=development nuxt prepare && eslint app --fix",
    "format:check": "prettier --check \"app/**/*.{js,ts,tsx,vue,json,css,md}\" \"docs/**/*.{md,markdown}\" \"*.md\" \".github/**/*.md\" \"DESIGN.md\" \"nuxt.config.ts\" \"app/app.config.ts\" \"vitest.config.ts\" \"tests/test-setup.ts\"",
    "generate": "nuxt generate",
    "i18n:check": "node scripts/lint-i18n.mjs",
    "i18n:translate": "node scripts/translate-i18n.mjs",
    "lint": "pnpm run design:lint && NODE_ENV=development nuxt prepare && eslint app --max-warnings=0",
    "typecheck": "NODE_ENV=development nuxt typecheck && tsc -p scripts/precompute",
    "lint:fix": "NODE_ENV=development nuxt prepare && eslint app --fix",
    "lint:unused": "knip --reporter compact",
    "postinstall": "nuxt prepare",
    "precompute:tarkov": "tsx --tsconfig scripts/precompute/tsconfig.json scripts/precompute/run.ts",
    "prepare": "husky || true",
    "preview": "nuxt preview",
    "setup": "bash scripts/setup-dev-environment.sh",
    "supabase:check": "bash scripts/check-supabase-db.sh",
    "supabase:types": "supabase gen types typescript --linked > supabase/functions/_shared/database.types.ts",
    "test": "vitest run --maxWorkers=2",
    "test:coverage": "vitest run --coverage --maxWorkers=2",
    "test:watch": "vitest --watch",
    "test:api-gateway": "vitest --config workers/api-gateway/vitest.config.ts",
    "validate:openapi": "pnpm --filter api-gateway run validate:openapi"
  },
  "type": "module",
  "lint-staged": {
    "app/**/*.{js,ts,tsx,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "app/**/*.{json,css,md}": [
      "prettier --write"
    ],
    "app/locales/*.json": [
      "node scripts/lint-i18n.mjs"
    ],
    "docs/**/*.{md,markdown}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    ".github/**/*.md": [
      "prettier --write"
    ],
    "DESIGN.md": [
      "prettier --write",
      "design.md lint"
    ],
    "tests/test-setup.ts": [
      "prettier --write"
    ],
    "nuxt.config.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "app/app.config.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "vitest*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
