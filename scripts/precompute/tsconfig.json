{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "#imports": ["./nuxt-imports.ts"],
      "@/*": ["../../app/*"],
      "~/*": ["../../app/*"]
    }
  },
  "include": ["./**/*.ts"]
}
